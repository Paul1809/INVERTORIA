{
  "name": "invenai-backend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate:dev": "prisma migrate dev --name init",
    "migrate:deploy": "prisma migrate deploy",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@prisma/adapter-pg": "^5.15.0",
    "@prisma/client": "^5.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.3"
  }
}